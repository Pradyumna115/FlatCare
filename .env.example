# FlatCare Environment Configuration
PORT=3000
SESSION_SECRET=enter_secure_secret_here

# Default Admin Credentials (used only during first-time seed)
ADMIN_USER=admin
ADMIN_PASS=changeme

# SMTP Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=FlatCare Reports <your_email@gmail.com>

# Email Recipients (comma-separated)
REPORT_RECIPIENTS=recipient1@example.com,recipient2@example.com
